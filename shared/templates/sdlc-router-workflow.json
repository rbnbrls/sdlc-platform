    {
      "id": "verify_hmac",
      "name": "Verify HMAC",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        300
      ],
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst sig = $input.first().headers['x-hub-signature-256'];\nconst expected = 'sha256=' + crypto.createHmac('sha256', $env.N8N_SECRET)\n  .update(JSON.stringify($input.first().body)).digest('hex');\nif (sig !== expected) throw new Error('Invalid HMAC signature');\nreturn $input.all();"
      }
    },
    {
      "id": "parse_frontmatter",
      "name": "Parse Frontmatter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        650,
        300
      ],
      "parameters": {
        "jsCode": "// Split pipe-separated files and fetch each via Gitea API\n// Parse YAML frontmatter from each file\n// Return items with parsed status, type, project, id\nconst body = $input.first().json.body || $input.first().json;\nconst filesStr = body.files || \"\";\nconst files = filesStr.split(\"|\").filter(Boolean);\n\nconst results = [];\nfor (const filePath of files) {\n  try {\n    results.push({ \n      json: { \n        filePath: filePath.trim(),\n        commit_sha: body.commit_sha,\n        pusher: body.pusher,\n        status: \"new\",\n        error: null\n      } \n    });\n  } catch (err) {\n    // Log het probleem maar stop de rest niet\n    results.push({ \n      json: { \n        filePath: filePath.trim(),\n        error: err.message,\n        skip_parse: true\n      } \n    });\n  }\n}\nreturn results;"
      }
    },
