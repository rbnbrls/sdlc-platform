    {
      "id": "dedup_check",
      "name": "Deduplication Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        300
      ],
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst processingStarted = item.processing_started;\nif (processingStarted) {\n  const startedAt = new Date(processingStarted);\n  const now = new Date();\n  const minutesSinceStart = (now - startedAt) / 1000 / 60;\n  if (minutesSinceStart < 5) {\n    return [{ json: { skip: true, reason: 'already_processing', item_id: item.id } }];\n  }\n}\nreturn [{ json: { ...item, skip: false } }];"
      }
    },
