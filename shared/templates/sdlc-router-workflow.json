      "id": "get_queue",
      "name": "GET QUEUE.json",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1150,
        600
      ],
      "parameters": {
        "url": "={{ $env.GITEA_URL }}/api/v1/repos/{{ $env.GITEA_ORG }}/sdlc-platform/contents/QUEUE.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "giteaApiToken",
          "name": "Gitea API Token"
        }
      }
    },
    {
      "id": "parse_append",
      "name": "Parse + append item",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        600
      ],
      "parameters": {
        "jsCode": "const file = $input.first().json;\nconst queue = JSON.parse(Buffer.from(file.content, 'base64').toString('utf8'));\nconst item = $('Parse Frontmatter').first().json;\n\nconst alreadyQueued = queue.queue.find(q => q.item_id === item.id);\nif (alreadyQueued) {\n  return [{ json: { enqueued: false, reason: 'already_in_queue', item_id: item.id, locked_by: $('Acquire Lock').first().json.locked_by || 'unknown' } }];\n}\n\nqueue.queue.push({\n  item_id: item.id,\n  file_path: item.filePath,\n  status: item.status,\n  project: item.project,\n  priority: item.priority || 'medium',\n  queued_at: new Date().toISOString(),\n  commit_sha: $('Webhook').first().json?.body?.after || ''\n});\n\nconst PRIORITY_WEIGHT = { critical: 4, high: 3, medium: 2, low: 1 };\nqueue.queue.sort((a, b) => {\n  const weightA = PRIORITY_WEIGHT[a.priority] || 2;\n  const weightB = PRIORITY_WEIGHT[b.priority] || 2;\n  if (weightB !== weightA) return weightB - weightA;\n  return new Date(a.queued_at) - new Date(b.queued_at);\n});\n\nqueue.last_updated = new Date().toISOString();\n\nreturn [{\n  json: {\n    content: Buffer.from(JSON.stringify(queue, null, 2)).toString('base64'),\n    sha: file.sha,\n    item_id: item.id,\n    locked_by: $('Acquire Lock').first().json.locked_by || 'unknown',\n    enqueued: true\n  }\n}];"
      }
    },
