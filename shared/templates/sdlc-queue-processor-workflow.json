            "node": "Is locked?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Is locked?": {
      "main": [
        [
          {
            "node": "IF locked",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF locked": {
      "main": [
        [],
        [
          {
            "node": "GET QUEUE.json",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "GET QUEUE.json": {
      "main": [
        [
          {
            "node": "Pop item from queue",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Pop item from queue": {
      "main": [
        [
          {
            "node": "IF queue empty",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF queue empty": {
      "main": [
        [],
        [
          {
            "node": "GET item frontmatter",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "GET item frontmatter": {
      "main": [
        [
          {
            "node": "Check status changed?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check status changed?": {
      "main": [
        [
          {
            "node": "IF status changed",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF status changed": {
      "main": [
        [
          {
            "node": "PUT QUEUE (item skipped)",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Acquire Lock",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Acquire Lock": {
      "main": [
        [
          {
            "node": "IF acquired",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF acquired": {
      "main": [
        [
          {
            "node": "PUT QUEUE (success)",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "PUT QUEUE (success)": {
      "main": [
        [
          {
            "node": "Prepare SDLC Router Auth",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Prepare SDLC Router Auth": {
      "main": [
        [
          {
            "node": "SDLC Router Trigger",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "SDLC Router Trigger": {
      "main": [
        [
          {
            "node": "Telegram: Started",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    "sdlc"
  ]
}